# ─── API キー ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

FAL_KEY=...

# ─── プロバイダ設定 ────────────────────────────────────────────────────────────
# 動画生成: local | fal
VIDEO_GEN_PROVIDER=local

# fal.ai 動画生成モデル（VIDEO_GEN_PROVIDER=fal 時に使用）
# fal-ai/kling-video/v2.1/standard/image-to-video
# fal-ai/kling-video/v1.6/standard/image-to-video
# fal-ai/wan/v2.1/image-to-video
# fal-ai/minimax/video-01-live
# fal-ai/luma-dream-machine/image-to-video
VIDEO_GEN_MODEL=fal-ai/kling-video/v1.6/standard/image-to-video

# 画像生成: sharp | fal | dalle
IMAGE_GEN_PROVIDER=sharp

# 音声合成: say | elevenlabs | voicevox
TTS_PROVIDER=say

# ─── モデル設定 ────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# ─── 生成設定 ──────────────────────────────────────────────────────────────────
VIDEOS_PER_PRODUCT=10

# ─── DB ────────────────────────────────────────────────────────────────────────
DB_PATH=./inoue-movie.db
