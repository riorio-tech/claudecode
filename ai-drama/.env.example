# ── 必須 ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
FAL_KEY=...
ELEVENLABS_API_KEY=...

# キャラクターボイス ID（ElevenLabs のボイス ID）
ELEVENLABS_VOICE_A=         # 主人公（学生）
ELEVENLABS_VOICE_B=         # 対立キャラ
ELEVENLABS_VOICE_NARRATOR=  # ナレーター

# NanoBanana Pro（画像生成）
NANOBANANA_API_KEY=
NANOBANANA_API_URL=https://api.nanobanana.pro/v1

# ── プロバイダ切替 ────────────────────────────────────────────────────────────
IMAGE_GEN_PROVIDER=nanobanana    # nanobanana | fal_flux | mock
VIDEO_GEN_PROVIDER=kling         # kling | local_ffmpeg

# ── 任意オーバーライド ────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLIP_DURATION_SEC=5
VARIANTS_PER_CONCEPT=3
DEFAULT_ARC_TEMPLATE=auto
SKIP_QA=false
DB_PATH=./ai-drama.db
